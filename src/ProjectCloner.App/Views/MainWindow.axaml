<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:ProjectCloner.App.ViewModels"
        mc:Ignorable="d" d:DesignWidth="820" d:DesignHeight="640"
        x:Class="ProjectCloner.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="820" Height="640" MinWidth="640" MinHeight="480"
        Title="ProjectCloner">

    <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="16">

        <!-- Top bar -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto" Margin="0,0,0,12">
            <TextBlock Grid.Column="0" Text="ProjectCloner" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
            <Button Grid.Column="1" Content="Check for updates" Command="{Binding CheckUpdatesCommand}" Margin="0,0,8,0"/>
            <Button Grid.Column="2" Content="Settings…" Click="OnOpenSettings"/>
        </Grid>

        <!-- Form -->
        <StackPanel Grid.Row="1" Spacing="8">
            <Grid ColumnDefinitions="140,*,Auto">
                <TextBlock Grid.Column="0" Text="Source project" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" Text="{Binding SourcePath}" PlaceholderText="Path to the source git repository"/>
                <Button Grid.Column="2" Content="Browse…" Click="OnBrowseSource" Margin="8,0,0,0"/>
            </Grid>
            <Grid ColumnDefinitions="140,*,Auto">
                <TextBlock Grid.Column="0" Text="Target folder" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" Text="{Binding TargetPath}" PlaceholderText="Destination folder for the clone (must be empty)"/>
                <Button Grid.Column="2" Content="Browse…" Click="OnBrowseTarget" Margin="8,0,0,0"/>
            </Grid>
            <Grid ColumnDefinitions="140,*">
                <TextBlock Grid.Column="0" Text="Source namespace" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" Text="{Binding SourceNamespace}" PlaceholderText="e.g. OldCompany.Web"/>
            </Grid>
            <Grid ColumnDefinitions="140,*">
                <TextBlock Grid.Column="0" Text="Target namespace" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" Text="{Binding TargetNamespace}" PlaceholderText="Optional — defaults to the target folder name"/>
            </Grid>

            <StackPanel Orientation="Horizontal" Spacing="20" Margin="140,4,0,0">
                <CheckBox Content="Dry run (no Bitbucket / push)" IsChecked="{Binding DryRun}"/>
                <CheckBox Content="Run build gate" IsChecked="{Binding RunBuilds}"/>
                <CheckBox Content="Backup database" IsChecked="{Binding BackupDatabase}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="8" Margin="140,4,0,0">
                <Button Content="Clone &amp; Push" Command="{Binding CloneCommand}" Padding="16,6" FontWeight="Bold"/>
                <Button Content="Cancel" Command="{Binding CancelCommand}" Padding="16,6"/>
                <ProgressBar IsIndeterminate="{Binding IsBusy}" Width="160" Height="6" VerticalAlignment="Center"
                             IsVisible="{Binding IsBusy}"/>
            </StackPanel>
        </StackPanel>

        <!-- Log -->
        <Border Grid.Row="2" Margin="0,12,0,0" BorderBrush="#333" BorderThickness="1" CornerRadius="4" Background="#161616">
            <ScrollViewer Name="LogScroll" Padding="8">
                <ItemsControl ItemsSource="{Binding Log}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:LogLine">
                            <TextBlock Text="{Binding Message}" Foreground="{Binding Color}"
                                       FontFamily="Cascadia Code,Consolas,Menlo,monospace" FontSize="12"
                                       TextWrapping="Wrap"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Status -->
        <TextBlock Grid.Row="3" Text="{Binding Status}" Margin="0,8,0,0" FontStyle="Italic" Opacity="0.8"/>
    </Grid>
</Window>
